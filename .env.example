# Copy ke .env (chmod 600). .env di-gitignore — secrets JANGAN masuk config.yaml.
# Bot Telegram (aktifkan juga telegram.enabled: true di config.yaml)
TELEGRAM_BOT_TOKEN=dari-@BotFather
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
# Auto-resolve issue Sentry setelah fix kedeploy (triggers.sentry.resolve: true)
# Bikin di sentry.io: Settings > Auth Tokens, scope event:write + project:read
SENTRY_AUTH_TOKEN=sntrys_xxx
# Integrasi Buffer.com (schedules promo-pagi/sore + scripts/buffer_post.py)
# Bikin di publish.buffer.com/settings/api
BUFFER_ACCESS_TOKEN=xxx
